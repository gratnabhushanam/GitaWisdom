				{
					"name": "Get Daily Sloka",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"var jsonData = pm.response.json();",
									"pm.test(\"Daily sloka has key fields\", function () {",
									"    pm.expect(jsonData).to.have.property('sanskrit');",
									"    pm.expect(jsonData).to.have.property('dailyKey');",
									"    pm.expect(jsonData).to.have.property('localizedMeaning');",
									"    pm.expect(jsonData.localizedMeaning).to.have.property('english');",
									"    pm.expect(jsonData.localizedMeaning).to.have.property('telugu');",
									"    pm.expect(jsonData.localizedMeaning).to.have.property('hindi');",
									"    pm.expect(jsonData).to.have.property('audioByLanguage');",
									"    pm.expect(jsonData.audioByLanguage).to.have.property('english');",
									"    pm.expect(jsonData.audioByLanguage).to.have.property('telugu');",
									"    pm.expect(jsonData.audioByLanguage).to.have.property('hindi');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/slokas/daily?date={{dailyDate}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"slokas",
								"daily"
							],
							"query": [
								{
									"key": "date",
									"value": "{{dailyDate}}"
								}
							]
						}
					},
					"response": []
				},
